<?xml version="1.0" encoding="UTF-8"?>

<?import com.github.nekozuki0509.schoolfes2026.*?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.media.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="pane" prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.nekozuki0509.schoolfes2026.Controller">
    <children>
        <ImageView fx:id="imageView" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
        <ProgressBar fx:id="progressBar" layoutX="40.0" layoutY="180.0" prefHeight="30.0" progress="0.0" visible="false" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="200.0" />
        <ImageView fx:id="problemImageView" fitHeight="150.0" pickOnBounds="true" visible="false" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0">
            <image>
                <Image url="@textures/png/problem.png" />
            </image>
        </ImageView>
      <Label fx:id="problemLabel" prefHeight="150.0" visible="false" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0" wrapText="true" minWidth="0" minHeight="0">
         <font>
            <Font name="System Bold" size="50.0" />
         </font>
      </Label>
        <ImageView fx:id="leftImageView" pickOnBounds="true" visible="false" AnchorPane.bottomAnchor="65.0" AnchorPane.leftAnchor="40.0" AnchorPane.topAnchor="270.0">
            <image>
                <Image url="@textures/png/left.png" />
            </image>
        </ImageView>
      <AutoShrinkLabel fx:id="leftLabel" alignment="CENTER" prefWidth="600.0" visible="false" AnchorPane.bottomAnchor="65.0" AnchorPane.leftAnchor="40.0" AnchorPane.topAnchor="270.0" minWidth="0" minHeight="0">
         <font>
            <Font name="System Bold" size="240.0" />
         </font>
      </AutoShrinkLabel>
        <ImageView fx:id="rightImageView" pickOnBounds="true" visible="false" AnchorPane.bottomAnchor="65.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="270.0">
            <image>
                <Image url="@textures/png/right.png" />
            </image>
        </ImageView>
      <AutoShrinkLabel fx:id="rightLabel" alignment="CENTER" prefWidth="600.0" visible="false" AnchorPane.bottomAnchor="65.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="270.0" minWidth="0" minHeight="0">
         <font>
            <Font name="System Bold" size="240.0" />
         </font>
      </AutoShrinkLabel>
    </children>
</AnchorPane>
